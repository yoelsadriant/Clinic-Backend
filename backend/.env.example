# Copy to .env and fill in values. Never commit .env to git.

# PostgreSQL (Docker Compose / RDS)
DATASOURCE_URL=jdbc:postgresql://localhost:5432/ibclinic
DATASOURCE_USERNAME=clinic_user
DATASOURCE_PASSWORD=change_me

# JWT — must be at least 32 bytes, random and secret
JWT_SECRET=replace-this-with-a-long-random-secret-value
JWT_EXPIRATION_MS=86400000

# ECS / Production
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012
# ECR_REPO=ibclinic-backend
